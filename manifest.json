{
  "manifest_version": 3,
  "name": "Quick Palette",
  "version": "0.5.1",
  "minimum_chrome_version": "121",
  "author": "Anoop K. Chandran",
  "description": "Search the web, open pages, and jump between tabs from one keyboard-first palette.",
  "permissions": [
    "activeTab",
    "bookmarks",
    "clipboardWrite",
    "history",
    "offscreen",
    "search",
    "scripting",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Quick Palette",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "commands": {
    "open-command-palette": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Quick Palette"
    },
    "copy-current-url": {
      "description": "Copy current tab URL"
    }
  }
}
